#!/bin/bash
SCRIPT_DIR="$HOME/moviebox-api"
DISTRO="pw24"

usage() {
    echo ""
    echo "  magpie install                    Setup proot + Ubuntu + Playwright"
    echo "  magpie migrate                    Enter the Ubuntu container"
    echo "  magpie start                      Install Python deps inside Ubuntu"
    echo "  magpie --mount <folder>           Move folder into storage/movies"
    echo "  magpie --download Title [flags]   Download a movie or series"
    echo ""
    echo "  magpie remove                     Uninstall magpie and clean everything"
    echo ""
    echo "  Flags: --pickN --sN --epN -a --info --url --json --upload"
    echo ""
}

case "$1" in

    install)
        command -v git &>/dev/null || pkg install -y git
        if [ ! -d "$HOME/moviebox-api" ]; then
            echo "[->] Cloning moviebox-api..."
            git clone https://github.com/engineermarcus/moviebox-api.git "$HOME/moviebox-api"
        fi
        bash "$HOME/moviebox-api/setup.sh"
        cp "$HOME/moviebox-api/magpie" "$PREFIX/bin/magpie"
        chmod +x "$PREFIX/bin/magpie"
        echo "[ok] magpie installed as global command"
        ;;

    remove)
        echo "[->] Removing magpie..."
        rm -rf "$HOME/moviebox-api"
        proot-distro remove pw24 2>/dev/null || true
        sed -i '/moviebox-api/d' ~/.bashrc 2>/dev/null || true
        sed -i '/moviebox-api/d' ~/.bash_profile 2>/dev/null || true
        rm -f "$PREFIX/bin/magpie"
        echo "[ok] magpie removed"
        echo "[!] Run: hash -r to clear shell cache"
        ;;

    migrate)
        proot-distro login "$DISTRO" --bind "$HOME:/root" --bind /sdcard:/sdcard
        ;;

    start)
        apt update && apt install zip -y
        pip install -r "$SCRIPT_DIR/requirements.txt" --break-system-packages
        python3 -m playwright install --with-deps chromium
        ;;

    --mount)
        if [ -z "$2" ]; then
            echo "[x] Usage: magpie --mount <folder>"
            exit 1
        fi
        mv -f "$2" "$SCRIPT_DIR/storage/movies"
        echo "[ok] Mounted $2 -> storage/movies"
        ;;

    --download)
        if [ -z "$2" ]; then
            echo "[x] Usage: magpie --download Title [flags]"
            exit 1
        fi
        shift
        python3 "$SCRIPT_DIR/downloader.py" "$@" 2>&1 || {
            echo "[!] Something went wrong. Run: magpie start"
        }
        ;;

    *)
        usage
        ;;
esac
