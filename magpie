#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# magpie — MovieBox CLI
# ─────────────────────────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DISTRO="pw24"

usage() {
    echo ""
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║                  magpie — MovieBox CLI                   ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""
    echo "  magpie install                        Setup proot + Ubuntu + Playwright"
    echo "  magpie migrate                        Enter the Ubuntu container"
    echo "  magpie start                          Install Python deps inside Ubuntu"
    echo "  magpie --mount <folder>               Move folder into storage/movies"
    echo "  magpie --download \"Movie\" [flags]     Download a movie or series"
    echo ""
    echo "  Download flags:"
    echo "    --s1          Season 1"
    echo "    --ep2         Episode 2"
    echo "    --pick1       Pick result #1"
    echo "    -a            Download all seasons"
    echo "    --json        JSON output"
    echo "    --info        Show info only"
    echo "    --url         Print stream URL only"
    echo "    --upload      Upload to Internet Archive"
    echo ""
}

case "$1" in

    # ── magpie install ────────────────────────────────────────────────────────
    install)
        bash "$SCRIPT_DIR/setup.sh"
        ;;

    # ── magpie migrate ────────────────────────────────────────────────────────
    migrate)
        export DISTRO=pw24
        proot-distro login "$DISTRO" --bind "$HOME:/root" --bind /sdcard:/sdcard
        ;;

    # ── magpie start ─────────────────────────────────────────────────────────
    start)
        apt update && apt install zip -y
        pip install -r "$SCRIPT_DIR/requirements.txt" --break-system-packages
        python3 -m playwright install --with-deps chromium
        ;;

    # ── magpie --mount <folder> ───────────────────────────────────────────────
    --mount)
        if [ -z "$2" ]; then
            echo "[✗] Usage: magpie --mount <folder>"
            exit 1
        fi
        mv -f "$2" "$SCRIPT_DIR/../storage/movies"
        echo "[✓] Mounted $2 → storage/movies"
        ;;

    # ── magpie --download ─────────────────────────────────────────────────────
    --download)
        if [ -z "$2" ]; then
            echo "[✗] Usage: magpie --download \"Movie Title\" [flags]"
            exit 1
        fi
        shift
        python3 "$SCRIPT_DIR/downloader.py" "$@" 2>&1 || {
            echo ""
            echo "[!] Something went wrong. If deps are missing, run: magpie start"
        }
        ;;

    # ── fallback ──────────────────────────────────────────────────────────────
    *)
        usage
        ;;
esac
